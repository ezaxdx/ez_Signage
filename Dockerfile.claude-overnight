# 야간 무중단 자율 실행 전용 sandbox.
# 사용:
#   docker build -f Dockerfile.claude-overnight -t claude-overnight .
#   docker run -it --rm \
#     -v $(pwd):/workspace \
#     -e ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY \
#     -e DAILY_BUDGET_USD=20 \
#     --network bridge \
#     claude-overnight \
#     /ralph-loop "$(cat prompt.md)" --max-iterations 30 --completion-promise "COMPLETE"

FROM node:20-slim

# 필수 도구
RUN apt-get update && apt-get install -y \
    git curl jq python3 python3-pip \
    build-essential ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# 비root 사용자 (시스템 보호)
RUN useradd -m -s /bin/bash claude
USER claude
WORKDIR /workspace

# Python 의존성 위해
ENV PATH="/home/claude/.local/bin:$PATH"

# 기본 CMD는 안전한 대화형 진입.
# overnight 모드(YOLO)는 컨테이너 실행 시 명시적으로 인자를 넘겨야 함:
#   docker run ... claude-overnight claude --dangerously-skip-permissions
# 이렇게 함으로써 이미지가 자동으로 unsafe 모드를 부팅하지 않음.
CMD ["claude"]
